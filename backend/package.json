{
  "name": "pet-store-backend",
  "private": true,
  "version": "0.0.0",
  "type": "commonjs",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "seed-admin": "tsx src/seedAdmin.ts",
    "seed-products": "tsx src/seedProducts.ts",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@aws-sdk/client-cost-explorer": "^3.1068.0",
    "@aws-sdk/client-dynamodb": "^3.1014.0",
    "@aws-sdk/client-s3": "^3.1014.0",
    "@aws-sdk/client-sns": "^3.1068.0",
    "@aws-sdk/lib-dynamodb": "^3.1014.0",
    "@aws-sdk/s3-request-presigner": "^3.1014.0",
    "@vendia/serverless-express": "^4.10.4",
    "bcryptjs": "^3.0.3",
    "cors": "latest",
    "express": "latest",
    "google-auth-library": "^10.7.0",
    "helmet": "latest",
    "jsonwebtoken": "^9.0.3"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "latest",
    "@types/express": "latest",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "latest",
    "@types/supertest": "^7.2.0",
    "@vitest/coverage-v8": "^4.1.9",
    "supertest": "^7.2.2",
    "tsx": "latest",
    "typescript": "latest",
    "vitest": "^4.1.9"
  }
}
